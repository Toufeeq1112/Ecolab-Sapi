<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core" xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">
	<error-handler name="error-handlerError_Handler" doc:id="838750e9-b954-4b1d-b309-453e7153984a" >
		<on-error-propagate enableNotifications="true" logException="true" doc:name="On Error Propagate" doc:id="fd96609d-67cc-4581-8f29-180f6e08fde1" type="ANY">
			<logger level="ERROR" doc:name="Logger" doc:id="438e681d-3bda-42b2-9f31-179c04a7e7dc" message='#["Error occured"]'/>
			<ee:transform doc:name="Transform Message" doc:id="2fbf458d-0710-4e1f-92ad-31fa44d2bd0b" >
				<ee:message >
					<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
error]]></ee:set-payload>
				</ee:message>
			</ee:transform>
		</on-error-propagate>
	</error-handler>
</mule>
